# ===================================================================
# FAIA System Environment Variables
# ===================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ===================================================================

# ===================================================================
# SECURITY — REQUIRED
# ===================================================================

# Generate a strong random secret key for JWT token signing
# Example (Linux/Mac): openssl rand -hex 32
# Example (Python):    python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# ===================================================================
# DATABASE — MySQL / MariaDB
# ===================================================================

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-database-password
DB_NAME=faia_chat_system

# ===================================================================
# AI MODEL PROVIDER
# ===================================================================
# Choose your model provider: local | ollama | openai
MODEL_PROVIDER=local

# Set to false if you want to skip local model loading entirely and rely on Ollama/OpenAI
LOAD_QWEN=true

# Set to true to enable the heavier RAG stack; false keeps the backend lightweight for smoke tests
ENABLE_RAG=false

# ── Local (HuggingFace transformers) ──────────────────────────────
# Download: huggingface-cli download Qwen/Qwen2.5-0.5B-Instruct
# Point to the downloaded folder:
# Example for your setup: QWEN_MODEL_PATH=D:\AI_Models\qwen-model
QWEN_MODEL_PATH=D:\AI_Models\qwen-model

# ── Ollama (easiest — no download if model already pulled) ─────────
# Install Ollama: https://ollama.com
# Pull a model: ollama pull qwen2.5:1.5b
# Then set:
# MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# ── OpenAI (cloud — requires API key) ─────────────────────────────
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # Optional — for Azure or compatible APIs

# ===================================================================
# SERVER PORTS — Optional, these are the defaults
# ===================================================================

MAIN_BACKEND_PORT=8000
ADMIN_BACKEND_PORT=8001
FRONTEND_PORT=8080
ADMIN_FRONTEND_PORT=5500

# ===================================================================
# SERVICE URLS — Optional, these are the defaults
# ===================================================================

ADMIN_URL=http://localhost:8001
BACKEND_URL=http://localhost:8000

# ===================================================================
# CORS — Optional, restrict in production
# ===================================================================
# Comma-separated list of allowed origins for the main backend
# CORS_ORIGINS=http://localhost:8080,https://yourdomain.com
# Comma-separated list of allowed origins for the admin panel
# ADMIN_CORS_ORIGINS=http://localhost:8090,https://admin.yourdomain.com
